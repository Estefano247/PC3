{
  "__inputs": [],
  "__requires": [],
  "title": "CallCenter",
  "version": 1,
  "timezone": "browser",
  "panels": [
    {
      "title": "Llamadas por hora",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": "PostgreSQL",
          "rawSql": "SELECT $__timeGroup(calldate,'1h') AS time, count(*) AS value FROM cdr WHERE $__timeFilter(calldate) GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "datasource": "PostgreSQL",
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0 }
      }
    },
    {
      "title": "Duración promedio (seg)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": "PostgreSQL",
          "rawSql": "SELECT $__timeGroup(calldate,'1h') AS time, avg(duration) AS value FROM cdr WHERE $__timeFilter(calldate) GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "datasource": "PostgreSQL",
      "fieldConfig": {
        "defaults": { "unit": "s", "min": 0 }
      }
    },
    {
      "title": "Llamadas por extensión",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "datasource": "PostgreSQL",
          "rawSql": "SELECT src AS label, count(*) AS value FROM cdr GROUP BY 1 ORDER BY 2 DESC LIMIT 10",
          "format": "table",
          "refId": "A"
        }
      ],
      "datasource": "PostgreSQL",
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "title": "Estado de llamadas",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "datasource": "PostgreSQL",
          "rawSql": "SELECT disposition AS label, count(*) AS value FROM cdr WHERE $__timeFilter(calldate) GROUP BY 1",
          "format": "table",
          "refId": "A"
        }
      ],
      "datasource": "PostgreSQL",
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "title": "Llamadas activas (últimos 5min)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 16 },
      "targets": [
        {
          "datasource": "PostgreSQL",
          "rawSql": "SELECT count(*) AS value FROM cdr WHERE calldate > now() - interval '5 minutes'",
          "format": "table",
          "refId": "A"
        }
      ],
      "datasource": "PostgreSQL",
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "background" } }
      }
    },
    {
      "title": "Duración total (hoy)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 16 },
      "targets": [
        {
          "datasource": "PostgreSQL",
          "rawSql": "SELECT coalesce(sum(duration),0) AS value FROM cdr WHERE calldate > CURRENT_DATE",
          "format": "table",
          "refId": "A"
        }
      ],
      "datasource": "PostgreSQL",
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Grabaciones (hoy)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 16 },
      "targets": [
        {
          "datasource": "PostgreSQL",
          "rawSql": "SELECT count(*) AS value FROM recordings WHERE created_at > CURRENT_DATE",
          "format": "table",
          "refId": "A"
        }
      ],
      "datasource": "PostgreSQL",
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "title": "Llamadas fallidas vs exitosas",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "targets": [
        {
          "datasource": "PostgreSQL",
          "rawSql": "SELECT $__timeGroup(calldate,'1h') AS time,\n  count(*) FILTER (WHERE disposition = 'ANSWERED') AS answered,\n  count(*) FILTER (WHERE disposition != 'ANSWERED') AS failed\nFROM cdr WHERE $__timeFilter(calldate) GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "datasource": "PostgreSQL",
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0 }
      }
    }
  ],
  "schemaVersion": 36
}
