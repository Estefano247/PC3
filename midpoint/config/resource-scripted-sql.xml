<?xml version="1.0" encoding="UTF-8"?>
<resource oid="00000000-0000-0000-0000-000000000001"
          xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
          xmlns:c="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
          xmlns:ri="http://midpoint.evolveum.com/xml/ns/public/resource/instance-3"
          xmlns:xsd="http://www.w3.org/2001/XMLSchema"
          xmlns:icfs="http://midpoint.evolveum.com/xml/ns/public/connector/icf-1/resource-schema-3"
          xmlns:sql="http://midpoint.evolveum.com/xml/ns/public/connector/scriptedsql/resource-schema-3">

    <name>CallCenter DB</name>

    <connectorRef type="ConnectorType">
        <filter>
            <q:equal xmlns:q="http://prism.evolveum.com/xml/ns/public/query-3">
                <q:path>connectorType</q:path>
                <q:value>ScriptedSQL</q:value>
            </q:equal>
        </filter>
    </connectorRef>

    <connectorConfiguration>
        <icfs:configurationProperties>
            <sql:driverClass>org.mariadb.jdbc.Driver</sql:driverClass>
            <sql:connectionString>jdbc:mariadb://db:3306/callcenter</sql:connectionString>
            <sql:user>callcenter</sql:user>
            <sql:password>CallCenter2024!</sql:password>
        </icfs:configurationProperties>
    </connectorConfiguration>

    <schema>
        <definition>
            <c:attribute>
                <c:name>uid</c:name>
                <c:ref>ri:uid</c:ref>
                <c:displayName>ID</c:displayName>
                <c:nativeAttributeName>id</c:nativeAttributeName>
            </c:attribute>
            <c:attribute>
                <c:name>username</c:name>
                <c:ref>ri:name</c:ref>
                <c:displayName>Username</c:displayName>
                <c:nativeAttributeName>username</c:nativeAttributeName>
            </c:attribute>
            <c:attribute>
                <c:name>full_name</c:name>
                <c:ref>ri:fullName</c:ref>
                <c:displayName>Full Name</c:displayName>
                <c:nativeAttributeName>full_name</c:nativeAttributeName>
            </c:attribute>
            <c:attribute>
                <c:name>sip_extension</c:name>
                <c:ref>ri:telephoneNumber</c:ref>
                <c:displayName>SIP Extension</c:displayName>
                <c:nativeAttributeName>sip_extension</c:nativeAttributeName>
            </c:attribute>
            <c:attribute>
                <c:name>sip_password</c:name>
                <c:ref>ri:password</c:ref>
                <c:displayName>SIP Password</c:displayName>
                <c:nativeAttributeName>sip_password</c:nativeAttributeName>
            </c:attribute>
            <c:attribute>
                <c:name>role</c:name>
                <c:ref>ri:role</c:ref>
                <c:displayName>Role</c:displayName>
                <c:nativeAttributeName>role</c:nativeAttributeName>
                <c:enumeration>
                    <c:value>AgenteCallCenter</c:value>
                    <c:value>Supervisor</c:value>
                    <c:value>Admin</c:value>
                </c:enumeration>
            </c:attribute>
            <c:attribute>
                <c:name>email</c:name>
                <c:ref>ri:email</c:ref>
                <c:displayName>Email</c:displayName>
                <c:nativeAttributeName>email</c:nativeAttributeName>
            </c:attribute>
            <c:attribute>
                <c:name>enabled</c:name>
                <c:ref>ri:enabled</c:ref>
                <c:displayName>Enabled</c:displayName>
                <c:nativeAttributeName>enabled</c:nativeAttributeName>
            </c:attribute>
        </definition>
    </schema>

    <schemaHandling>
        <objectType>
            <ri:account>true</ri:account>
            <ri:default>true</ri:default>
            <attribute>
                <c:ref>ri:uid</c:ref>
                <c:signDisplayOrder>1</c:signDisplayOrder>
                <matchingRule>http://midpoint.evolveum.com/xml/ns/public/matching-rule-3#integer</matchingRule>
                <displayName>ID</displayName>
            </attribute>
            <attribute>
                <c:ref>ri:name</c:ref>
                <c:signDisplayOrder>2</c:signDisplayOrder>
                <matchingRule>http://midpoint.evolveum.com/xml/ns/public/matching-rule-3#stringIgnoreCase</matchingRule>
                <displayName>Username</displayName>
            </attribute>
            <attribute>
                <c:ref>ri:telephoneNumber</c:ref>
                <c:signDisplayOrder>3</c:signDisplayOrder>
                <displayName>SIP Extension</displayName>
            </attribute>
            <attribute>
                <c:ref>ri:role</c:ref>
                <c:signDisplayOrder>4</c:signDisplayOrder>
                <displayName>Role</displayName>
            </attribute>
            <attribute>
                <c:ref>ri:enabled</c:ref>
                <c:signDisplayOrder>5</c:signDisplayOrder>
                <displayName>Enabled</displayName>
            </attribute>
        </objectType>
    </schemaHandling>

    <synchronization>
        <enabled>true</enabled>
        <reconciliation>
            <processing>addAttributeValues</processing>
        </reconciliation>
        <correlation>
            <correlators>
                <items>
                    <item>
                        <path>ri:name</path>
                    </item>
                </items>
            </correlators>
        </correlation>
        <reactions>
            <reaction>
                <situation>linked</situation>
                <processing>fullSynchronization</processing>
                <actions>
                    <executeScript>
                        <script>
                            <code>
                                log.info("Provisioning SIP extension for user: " + username)
                                log.info("Extension: " + telephoneNumber + ", Role: " + role)

                                // Only provision if role is AgenteCallCenter and extension exists
                                if ("AgenteCallCenter".equals(role) && telephoneNumber != null) {
                                    def scriptPath = "/opt/midpoint/scripts/provision-asterisk.py"
                                    def args = [String.valueOf(id), name, telephoneNumber, password, fullName]

                                    log.info("Running: " + scriptPath + " " + args.join(" "))
                                    def proc = Runtime.getRuntime().exec(["python3", scriptPath] + args)
                                    def stdout = new BufferedReader(new InputStreamReader(proc.getInputStream()))
                                    def stderr = new BufferedReader(new InputStreamReader(proc.getErrorStream()))

                                    String line
                                    while ((line = stdout.readLine()) != null) { log.info(line) }
                                    while ((line = stderr.readLine()) != null) { log.warn(line) }

                                    def exitCode = proc.waitFor()
                                    log.info("Provision script exited with code: " + exitCode)
                                } else {
                                    log.info("User " + name + " not an AgenteCallCenter, skipping")
                                }
                            </code>
                        </script>
                    </executeScript>
                </actions>
            </reaction>
            <reaction>
                <situation>unlinked</situation>
                <processing>fullSynchronization</processing>
                <actions>
                    <executeScript>
                        <script>
                            <code>
                                log.info("Deprovisioning SIP extension: " + telephoneNumber)
                                if (telephoneNumber != null) {
                                    def scriptPath = "/opt/midpoint/scripts/deprovision-asterisk.py"
                                    def proc = Runtime.getRuntime().exec(["python3", scriptPath, String.valueOf(telephoneNumber)])
                                    def stdout = new BufferedReader(new InputStreamReader(proc.getInputStream()))
                                    def stderr = new BufferedReader(new InputStreamReader(proc.getErrorStream()))

                                    String line
                                    while ((line = stdout.readLine()) != null) { log.info(line) }
                                    while ((line = stderr.readLine()) != null) { log.warn(line) }

                                    def exitCode = proc.waitFor()
                                    log.info("Deprovision script exited with code: " + exitCode)
                                }
                            </code>
                        </script>
                    </executeScript>
                </actions>
            </reaction>
        </reactions>
    </synchronization>

    <connectorScript>
        <searchScript>
            <code>
                // Search all active users from the callcenter DB
                SELECT id AS uid, username, full_name, sip_extension, sip_password, role, email, enabled
                FROM users
                WHERE enabled = 1
            </code>
        </searchScript>
        <readScript>
            <code>
                // Read a single user by ID
                SELECT id AS uid, username, full_name, sip_extension, sip_password, role, email, enabled
                FROM users WHERE id = ${uid}
            </code>
        </readScript>
        <createScript>
            <code>
                // Create a new user (provisioned by midPoint)
                INSERT INTO users (username, full_name, email, role, sip_extension, sip_password, enabled)
                VALUES ('${username}', '${fullName}', '${email}', '${role}', '${telephoneNumber}', '${password}', ${enabled})
            </code>
        </createScript>
        <updateScript>
            <code>
                // Update an existing user
                UPDATE users
                SET full_name = '${fullName}',
                    email = '${email}',
                    role = '${role}',
                    sip_extension = '${telephoneNumber}',
                    sip_password = '${password}',
                    enabled = ${enabled}
                WHERE id = ${uid}
            </code>
        </updateScript>
        <deleteScript>
            <code>
                // Soft-delete: disable the user
                UPDATE users SET enabled = 0 WHERE id = ${uid}
            </code>
        </deleteScript>
    </connectorScript>
</resource>
