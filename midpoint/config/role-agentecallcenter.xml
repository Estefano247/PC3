<?xml version="1.0" encoding="UTF-8"?>
<role oid="00000000-0000-0000-0000-000000000010"
      xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
      xmlns:c="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
      xmlns:ri="http://midpoint.evolveum.com/xml/ns/public/resource/instance-3"
      xmlns:xsd="http://www.w3.org/2001/XMLSchema">

    <name>AgenteCallCenter</name>
    <description>Rol para agentes del call center con extensión SIP</description>
    <displayName>Agente de Call Center</displayName>

    <inducement>
        <description>Provision SIP extension on Asterisk</description>
        <construction>
            <resourceRef oid="00000000-0000-0000-0000-000000000001"
                         type="ResourceType"/>
            <kind>account</kind>
            <intent>agent</intent>
            <attribute>
                <c:ref>ri:telephoneNumber</c:ref>
                <outbound>
                    <source>
                        <path>telephoneNumber</path>
                    </source>
                </outbound>
            </attribute>
            <attribute>
                <c:ref>ri:role</c:ref>
                <outbound>
                    <source>
                        <path>role</path>
                    </source>
                </outbound>
            </attribute>
        </construction>
    </inducement>
</role>
